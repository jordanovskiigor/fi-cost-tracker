MODULE user_command_0100 INPUT.
CASE sy-ucomm.
  WHEN 'DISP'.
    SET SCREEN 200.
  WHEN 'CRT'.
    SET SCREEN 300.
  WHEN 'BACK'.
    LEAVE PROGRAM.
ENDCASE.
ENDMODULE.